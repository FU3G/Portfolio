# Variables d'environnement — copier ce fichier en .env et remplir les valeurs
# Le fichier .env ne doit PAS être commité (il est dans .gitignore)

# Endpoint Formspree pour le formulaire de contact
# 1. Créer un compte sur https://formspree.io
# 2. Créer un nouveau formulaire
# 3. Copier l'URL de l'endpoint ici
VITE_FORMSPREE_URL=https://formspree.io/f/VOTRE_ID
